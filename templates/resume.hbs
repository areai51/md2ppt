<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.5;
      color: #2d2d2d;
      background: #fff;
    }

    /* ── HEADER ── */
    .resume-header {
      background: #1b262c;
      color: white;
      padding: 40px 56px;
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .header-avatar {
      width: 80px; height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, #00b4d8, #0077b6);
      display: flex; align-items: center; justify-content: center;
      font-size: 28pt; font-weight: 700; color: white;
      flex-shrink: 0;
    }

    .header-info h1 {
      font-size: 22pt;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: white;
      margin: 0 0 4px;
    }

    .header-role {
      font-size: 11pt;
      color: #00b4d8;
      font-weight: 500;
      margin-bottom: 10px;
    }

    .header-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 20px;
      font-size: 9pt;
      color: rgba(255,255,255,0.65);
    }

    /* ── BODY LAYOUT ── */
    .resume-body {
      display: grid;
      grid-template-columns: 220px 1fr;
      min-height: calc(100vh - 160px);
    }

    /* ── SIDEBAR ── */
    .sidebar {
      background: #f4f8fb;
      padding: 36px 28px;
      border-right: 1px solid #e0e8ee;
    }

    .sidebar-section { margin-bottom: 28px; }

    .sidebar-label {
      font-size: 7.5pt;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #0077b6;
      margin-bottom: 10px;
      padding-bottom: 4px;
      border-bottom: 2px solid #00b4d8;
    }

    .skill-bar {
      margin-bottom: 8px;
    }
    .skill-bar span {
      font-size: 9pt;
      display: block;
      margin-bottom: 3px;
      color: #333;
    }
    .skill-track {
      height: 4px;
      background: #dde8f0;
      border-radius: 2px;
      overflow: hidden;
    }
    .skill-fill {
      height: 100%;
      background: linear-gradient(90deg, #0077b6, #00b4d8);
      border-radius: 2px;
    }

    /* ── MAIN CONTENT ── */
    .main {
      padding: 36px 48px;
    }

    h1 { display: none; } /* Hidden — shown in header */
    h2 {
      font-size: 11pt;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #0077b6;
      border-bottom: 2px solid #e0e8ee;
      padding-bottom: 6px;
      margin-bottom: 16px;
      margin-top: 28px;
    }
    h2:first-child { margin-top: 0; }
    h3 {
      font-size: 11pt;
      font-weight: 600;
      color: #1b262c;
      margin-bottom: 2px;
    }
    h4 {
      font-size: 9.5pt;
      font-weight: 400;
      color: #0077b6;
      margin-bottom: 4px;
    }
    p { margin-bottom: 0.7em; font-size: 9.5pt; color: #444; }

    ul {
      margin: 0.3em 0 0.8em 1.2em;
      list-style: none;
      padding: 0;
    }
    li {
      margin-bottom: 4px;
      font-size: 9.5pt;
      color: #444;
      padding-left: 1em;
      position: relative;
    }
    li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: #00b4d8;
      font-size: 8pt;
    }

    .job-meta {
      display: flex;
      justify-content: space-between;
      font-size: 8.5pt;
      color: #888;
      margin-bottom: 6px;
    }

    /* ── PRINT ── */
    @media print {
      body { font-size: 9.5pt; }
      .resume-header, .sidebar {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>

  <div class="resume-header">
    <div class="header-avatar">
      {{#if initials}}{{initials}}{{else}}{{#if title}}{{slice title 0 1}}{{else}}?{{/if}}{{/if}}
    </div>
    <div class="header-info">
      <h1>{{#if title}}{{title}}{{else}}Full Name{{/if}}</h1>
      <div class="header-role">{{#if role}}{{role}}{{else}}Professional Title{{/if}}</div>
      <div class="header-contact">
        {{#if email}}<span>✉ {{email}}</span>{{/if}}
        {{#if phone}}<span>✆ {{phone}}</span>{{/if}}
        {{#if location}}<span>⌖ {{location}}</span>{{/if}}
        {{#if website}}<span>⬡ {{website}}</span>{{/if}}
      </div>
    </div>
  </div>

  <div class="resume-body">
    <div class="sidebar">
      <!-- Sidebar rendered by separate partial or manually -->
      {{#if skills_sidebar}}
        <div class="sidebar-section">
          <div class="sidebar-label">Skills</div>
          {{{skills_sidebar}}}
        </div>
      {{/if}}
    </div>
    <div class="main">
      {{{content}}}
    </div>
  </div>

</body>
</html>
