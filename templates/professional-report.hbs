<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 11pt;
      line-height: 1.7;
      color: #1a1a2e;
      background: #fff;
    }

    /* ── COVER PAGE ── */
    .cover {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      background: linear-gradient(135deg, #0f3460 0%, #16213e 60%, #1a1a2e 100%);
      color: white;
      padding: 80px 72px;
      page-break-after: always;
      position: relative;
      overflow: hidden;
    }

    .cover::before {
      content: '';
      position: absolute;
      top: -100px; right: -100px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(233,69,96,0.25) 0%, transparent 70%);
      border-radius: 50%;
    }

    .cover::after {
      content: '';
      position: absolute;
      bottom: -80px; left: -80px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(22,158,255,0.2) 0%, transparent 70%);
      border-radius: 50%;
    }

    .cover-logo {
      font-size: 13pt;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      opacity: 0.7;
      z-index: 1;
    }

    .cover-main { z-index: 1; }

    .cover-tag {
      display: inline-block;
      background: rgba(233,69,96,0.9);
      color: white;
      font-size: 8pt;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 2px;
      margin-bottom: 28px;
    }

    .cover h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 42pt;
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 20px;
      letter-spacing: -0.5px;
    }

    .cover-subtitle {
      font-size: 14pt;
      font-weight: 300;
      opacity: 0.75;
      max-width: 480px;
    }

    .cover-footer {
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      border-top: 1px solid rgba(255,255,255,0.15);
      padding-top: 24px;
    }

    .cover-meta { font-size: 10pt; opacity: 0.65; }
    .cover-meta strong { display: block; opacity: 1; font-weight: 500; }

    /* ── CONTENT ── */
    .content {
      max-width: 720px;
      margin: 0 auto;
      padding: 60px 72px;
    }

    h1, h2, h3, h4, h5, h6 {
      font-weight: 600;
      line-height: 1.25;
      margin-top: 2em;
      margin-bottom: 0.6em;
      color: #0f3460;
    }

    h1 { font-size: 22pt; border-bottom: 3px solid #e94560; padding-bottom: 10px; }
    h2 { font-size: 16pt; border-bottom: 1px solid #e0e0e0; padding-bottom: 8px; }
    h3 { font-size: 13pt; color: #16213e; }
    h4 { font-size: 11pt; color: #16213e; font-weight: 600; }

    p { margin-bottom: 1em; }

    a { color: #e94560; text-decoration: none; }

    strong { font-weight: 600; color: #0f3460; }
    em { font-style: italic; color: #444; }

    /* Tables */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5em 0;
      font-size: 10pt;
    }
    thead {
      background: #0f3460;
      color: white;
    }
    thead th {
      padding: 10px 14px;
      text-align: left;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    tbody tr:nth-child(even) { background: #f8f9fc; }
    tbody tr:hover { background: #eef1f8; }
    tbody td {
      padding: 9px 14px;
      border-bottom: 1px solid #e5e9f0;
    }

    /* Code */
    code {
      background: #f0f3f9;
      color: #c7254e;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 9pt;
      padding: 2px 6px;
      border-radius: 3px;
    }
    pre {
      background: #1a1a2e;
      color: #e2e8f0;
      padding: 20px 24px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1.5em 0;
      border-left: 4px solid #e94560;
    }
    pre code {
      background: none;
      color: inherit;
      padding: 0;
      font-size: 9pt;
      line-height: 1.6;
    }

    /* Blockquotes */
    blockquote {
      border-left: 4px solid #e94560;
      margin: 1.5em 0;
      padding: 12px 20px;
      background: #fef5f7;
      color: #555;
      font-style: italic;
      border-radius: 0 4px 4px 0;
    }

    /* Lists */
    ul, ol {
      margin: 0.8em 0 0.8em 1.5em;
    }
    li { margin-bottom: 0.3em; }
    li::marker { color: #e94560; }

    /* Callout / Info box using blockquote with > **Note** */
    blockquote strong:first-child {
      display: block;
      color: #0f3460;
      font-style: normal;
      margin-bottom: 4px;
    }

    /* Horizontal Rule */
    hr {
      border: none;
      border-top: 2px solid #e5e9f0;
      margin: 2em 0;
    }

    /* Page numbers */
    @page { margin: 0; }
    .page-number {
      position: fixed;
      bottom: 24px;
      right: 48px;
      font-size: 9pt;
      color: #999;
    }

    /* Print */
    @media print {
      body { font-size: 10.5pt; }
      .cover { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      pre, blockquote, table { page-break-inside: avoid; }
      h2, h3 { page-break-after: avoid; }
    }
  </style>
</head>
<body>

  <!-- Cover Page -->
  <div class="cover">
    <div class="cover-logo">{{#if author}}{{author}}{{else}}Professional Report{{/if}}</div>
    <div class="cover-main">
      <div class="cover-tag">Report</div>
      <h1>{{#if title}}{{title}}{{else}}Document Title{{/if}}</h1>
      {{#if subtitle}}<p class="cover-subtitle">{{subtitle}}</p>{{/if}}
    </div>
    <div class="cover-footer">
      <div class="cover-meta">
        <strong>Prepared by</strong>
        {{#if author}}{{author}}{{else}}—{{/if}}
      </div>
      <div class="cover-meta" style="text-align:right">
        <strong>Date</strong>
        {{#if date}}{{date}}{{else}}—{{/if}}
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">
    {{{content}}}
  </div>

</body>
</html>
