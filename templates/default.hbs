<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if frontMatter.title}}{{frontMatter.title}}{{else}}Document{{/if}}</title>
  <style>
    {{{styles}}}
  </style>
</head>
<body>
  {{#if (hasPartial "header")}}
    {{> header}}
  {{/if}}

  <main>
    {{{content}}}
  </main>

  {{#if (hasPartial "footer")}}
    {{> footer}}
  {{/if}}
</body>
</html>
