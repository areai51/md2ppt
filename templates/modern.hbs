<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if frontMatter.title}}{{frontMatter.title}}{{else}}Document{{/if}}</title>
  <style>
    :root {
      --primary: #2563eb;
      --text: #1f2937;
      --muted: #6b7280;
      --bg: #ffffff;
      --code-bg: #f3f4f6;
    }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      line-height: 1.75;
      color: var(--text);
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
      background: var(--bg);
    }
    h1, h2, h3, h4 {
      font-weight: 700;
      line-height: 1.3;
      color: var(--text);
    }
    h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      border-bottom: 3px solid var(--primary);
      padding-bottom: 0.5rem;
    }
    h2 {
      font-size: 1.75rem;
      margin-top: 2.5rem;
      color: var(--primary);
    }
    h3 { font-size: 1.25rem; margin-top: 2rem; }
    p { margin-bottom: 1.25rem; }
    a {
      color: var(--primary);
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    a:hover { border-bottom-color: var(--primary); }
    code {
      background: var(--code-bg);
      padding: 0.2em 0.5em;
      border-radius: 4px;
      font-size: 0.9em;
      font-family: 'JetBrains Mono', monospace;
    }
    pre {
      background: var(--code-bg);
      padding: 1.25rem;
      border-radius: 8px;
      overflow-x: auto;
      font-size: 0.875rem;
    }
    pre code { background: none; padding: 0; }
    blockquote {
      border-left: 4px solid var(--primary);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1.5rem;
      color: var(--muted);
      font-style: italic;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }
    th, td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }
    th {
      background: var(--code-bg);
      font-weight: 600;
    }
    hr {
      border: none;
      height: 2px;
      background: linear-gradient(to right, var(--primary), transparent);
      margin: 3rem 0;
    }
    @media print {
      body { padding: 2cm; }
      h2 { page-break-after: avoid; }
    }
  </style>
</head>
<body>
  <main>{{{content}}}</main>
</body>
</html>
