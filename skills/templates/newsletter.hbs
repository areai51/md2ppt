<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 11pt;
      line-height: 1.8;
      color: #333;
      background: #f0ebe3;
    }

    /* ── WRAPPER ── */
    .wrapper {
      max-width: 680px;
      margin: 32px auto;
      background: #fff;
      border: 1px solid #ddd;
      box-shadow: 0 2px 20px rgba(0,0,0,0.08);
    }

    /* ── MASTHEAD ── */
    .masthead {
      background: #1a1a1a;
      color: white;
      padding: 48px 56px 36px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .masthead::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: linear-gradient(90deg, #d4a437, #e8c46a, #d4a437);
    }

    .masthead-label {
      font-family: -apple-system, 'Helvetica Neue', sans-serif;
      font-size: 8pt;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #d4a437;
      margin-bottom: 14px;
    }

    .masthead h1 {
      font-size: 30pt;
      font-weight: 700;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 10px;
      color: white;
    }

    .masthead-meta {
      font-family: -apple-system, 'Helvetica Neue', sans-serif;
      font-size: 9pt;
      color: rgba(255,255,255,0.5);
      letter-spacing: 0.5px;
    }

    /* ── BODY ── */
    .body {
      padding: 48px 56px;
    }

    h1 { display: none; } /* Used in masthead */

    h2 {
      font-size: 17pt;
      font-weight: 700;
      color: #1a1a1a;
      margin-top: 2em;
      margin-bottom: 0.5em;
      line-height: 1.2;
      position: relative;
      padding-bottom: 10px;
    }
    h2::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 40px; height: 3px;
      background: #d4a437;
    }

    h3 {
      font-size: 13pt;
      color: #222;
      margin-top: 1.5em;
      margin-bottom: 0.4em;
    }

    p { margin-bottom: 1em; }

    p:first-of-type::first-letter {
      font-size: 3em;
      font-weight: 700;
      float: left;
      line-height: 0.75;
      padding-right: 8px;
      padding-top: 4px;
      color: #d4a437;
    }

    blockquote {
      border-left: 3px solid #d4a437;
      margin: 1.8em 0;
      padding: 16px 24px;
      background: #fdf8f0;
      font-style: italic;
      font-size: 12pt;
      color: #555;
    }

    a { color: #b8860b; }

    ul, ol { margin: 0.8em 0 0.8em 1.6em; }
    li { margin-bottom: 0.4em; }

    hr {
      border: none;
      text-align: center;
      margin: 2em 0;
      color: #ccc;
    }
    hr::before {
      content: '— ◆ —';
      letter-spacing: 6px;
      color: #ccc;
      font-size: 9pt;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5em 0;
      font-size: 10pt;
    }
    th {
      background: #1a1a1a;
      color: white;
      padding: 8px 14px;
      text-align: left;
      font-family: -apple-system, sans-serif;
      font-size: 9pt;
      letter-spacing: 0.5px;
    }
    td {
      padding: 8px 14px;
      border-bottom: 1px solid #eee;
    }
    tr:nth-child(even) td { background: #fdf8f0; }

    code {
      font-family: 'SF Mono', monospace;
      font-size: 9pt;
      background: #f5f0e8;
      padding: 1px 5px;
      border-radius: 2px;
    }

    /* ── FOOTER ── */
    .footer {
      background: #1a1a1a;
      color: rgba(255,255,255,0.5);
      text-align: center;
      padding: 28px 56px;
      font-family: -apple-system, 'Helvetica Neue', sans-serif;
      font-size: 8.5pt;
      letter-spacing: 0.3px;
    }

    .footer a { color: #d4a437; }

    /* ── PRINT ── */
    @media print {
      body { background: white; }
      .wrapper { box-shadow: none; border: none; margin: 0; }
      .masthead { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .footer { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <div class="masthead">
      <div class="masthead-label">Newsletter</div>
      <h1>{{#if title}}{{title}}{{else}}The Weekly Brief{{/if}}</h1>
      <div class="masthead-meta">
        {{#if author}}By {{author}} · {{/if}}{{#if date}}{{date}}{{/if}}
      </div>
    </div>

    <div class="body">
      {{{content}}}
    </div>

    <div class="footer">
      {{#if footer_text}}{{footer_text}}{{else}}
        You're receiving this because you subscribed. ·
        <a href="#">Unsubscribe</a>
      {{/if}}
    </div>

  </div>
</body>
</html>
